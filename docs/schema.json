{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "rules.schema.json",
  "title": "redpolitika rules file",
  "type": "object",
  "required": ["rules"],
  "additionalProperties": false,
  "properties": {
    "rules": {
      "type": "array",
      "items": { "$ref": "#/$defs/rule" }
    }
  },
  "$defs": {
    "rule": {
      "type": "object",
      "required": ["id", "severity", "category", "detect"],
      "properties": {
        "id": {
          "type": "string",
          "pattern": "^[a-z0-9_-]+(/[a-z0-9_-]+)+$"
        },
        "severity": { "type": "integer", "minimum": 1, "maximum": 10 },
        "category": {
          "type": "string",
          "enum": ["cleanliness", "readability"]
        },
        "name": { "type": "string" },
        "url": { "type": "string" },
        "suggestion": { "type": "string" },
        "enabled": { "type": "boolean" },
        "detect": { "$ref": "#/$defs/detectNode" },
        "fix": { "$ref": "#/$defs/fixNode" },
        "examples": {
          "type": "object",
          "properties": {
            "bad": { "type": "array", "items": { "type": "string" } },
            "good": { "type": "array", "items": { "type": "string" } }
          }
        },
        "related": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["name"],
            "properties": {
              "name": { "type": "string" },
              "url": { "type": "string" }
            }
          }
        }
      },
      "additionalProperties": false
    },
    "detectNode": {
      "description": "Detect method tree (key-as-method or nested)",
      "type": "object"
    },
    "fixNode": {
      "description": "Fix method tree (key-as-method or nested)",
      "type": "object"
    }
  }
}
